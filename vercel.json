{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/compatibility", "dest": "api/index.py" },
    { "src": "/api/leads", "dest": "api/index.py" },
    { "src": "/api/chat", "dest": "api/index.py" },
    { "src": "/leads", "dest": "api/index.py" }
  ]
}