# Скопируйте в .env и заполните значения.

# Уведомления о заявках в Telegram:
# 1) Создайте бота через @BotFather, возьмите токен.
# 2) Напишите боту любое сообщение, затем откройте:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    и найдите "chat":{"id": ... } — это TELEGRAM_CHAT_ID (для личного чата положительное число).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Если api.telegram.org не открывается (провайдер, без VPN): укажите HTTPS-прокси.
# Пример: TELEGRAM_HTTPS_PROXY=http://127.0.0.1:7890
TELEGRAM_HTTPS_PROXY=

# Куда писать JSONL, если Telegram так и не ответил (по умолчанию backend/telegram_failed_leads.jsonl).
# LEAD_TELEGRAM_FALLBACK_LOG=

# Чат DeepSeek: меньше токенов — быстрее ответ (диапазон 120–800 в коде).
# DEEPSEEK_CHAT_MAX_TOKENS=400
# DEEPSEEK_CHAT_HISTORY_MSGS=12
